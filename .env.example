# QuantBot Configuration
# Copy this to .env and customize

# --- LLM Provider ---
# "ollama" (local Mac), "sglang" (GPU cluster), "openai", "anthropic"
DEFAULT_PROVIDER=ollama

# --- Ollama (local models — no API key needed) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- SGLang / vLLM (self-hosted on GPU cluster) ---
# Serves models with OpenAI-compatible API. Use "sglang:" prefix in model names.
# OPENAI_BASE_URL=http://your-slurm-node:30000/v1
#
# Example SLURM launch:
#   srun --gres=gpu:h200:2 python -m sglang.launch_server \
#     --model-path meta-llama/Llama-3.3-70B-Instruct \
#     --port 30000 --tp 2
#
# Then set models like:
#   INDICATOR_MODEL=sglang:meta-llama/Llama-3.3-70B-Instruct
#   DECISION_MODEL=sglang:deepseek-ai/DeepSeek-R1

# --- Per-Agent Model Selection ---
# Ollama models (local, free):
INDICATOR_MODEL=qwen3:14b
PATTERN_MODEL=qwen3-vl
TREND_MODEL=qwen3-vl
DEBATE_MODEL=qwen3:14b
DECISION_MODEL=qwen3:14b
BACKTEST_MODEL=qwen3:14b

# SGLang models (self-hosted GPU cluster):
# INDICATOR_MODEL=sglang:meta-llama/Llama-3.3-70B-Instruct
# PATTERN_MODEL=sglang:Qwen/Qwen2.5-VL-72B-Instruct
# TREND_MODEL=sglang:Qwen/Qwen2.5-VL-72B-Instruct
# DEBATE_MODEL=sglang:meta-llama/Llama-3.3-70B-Instruct
# DECISION_MODEL=sglang:deepseek-ai/DeepSeek-R1
# BACKTEST_MODEL=sglang:SUFE-AIFLM-Lab/Fin-R1

# Cloud API models:
# INDICATOR_MODEL=gpt-4o
# PATTERN_MODEL=claude-sonnet-4-20250514
# TREND_MODEL=claude-sonnet-4-20250514
# DEBATE_MODEL=claude-sonnet-4-20250514
# DECISION_MODEL=claude-opus-4-20250514
# BACKTEST_MODEL=gpt-4o-mini

# --- API Keys (only needed for cloud/sglang models) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- Instruments ---
INSTRUMENTS=BTC-USD,SPY,ES=F,GC=F

# --- TSMOM Parameters ---
TSMOM_VOL_TARGET=0.40
TSMOM_EWMA_COM=60

# --- Signal Combiner Weights ---
WEIGHT_TSMOM=0.50
WEIGHT_INDICATOR=0.20
WEIGHT_PATTERN=0.15
WEIGHT_TREND=0.15

# --- Risk Limits ---
MAX_POSITION_PCT=0.20
MAX_GROSS_LEVERAGE=2.0
MAX_SINGLE_TRADE_PCT=0.05

# --- Debate ---
DEBATE_ENABLED=true
DEBATE_MAX_ROUNDS=2

# --- Backtest ---
CACHE_LLM_RESPONSES=true

# --- Memory ---
MEMORY_DB_PATH=~/.quantbot/memory.db
